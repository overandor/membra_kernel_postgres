DATABASE_URL=postgresql+psycopg://membra_user:membra_pass@localhost:5432/membra

# For development only. In production, run Alembic migrations instead.
AUTO_CREATE_TABLES=false

# Separate role keys. The server derives role from the key. No X-Membra-Role header exists.
MEMBRA_ADMIN_KEY=replace-admin-secret
MEMBRA_OPS_KEY=replace-ops-secret
MEMBRA_INSURANCE_KEY=replace-insurance-secret
MEMBRA_CLAIMS_KEY=replace-claims-secret
MEMBRA_SCANNER_KEY=replace-scanner-secret
MEMBRA_READONLY_KEY=replace-readonly-secret

# Compatibility fallback only. Prefer MEMBRA_ADMIN_KEY for production.
PLATFORM_API_KEY=replace-platform-secret

# PII encryption and QR signing. Keep these separate in production.
MEMBRA_DATA_ENCRYPTION_KEY=replace-data-encryption-secret
ACCESS_SIGNING_SECRET=replace-access-signing-secret
WEBHOOK_SECRET=replace-webhook-secret

INSURANCE_PROVIDER_NAME=your_licensed_partner
INSURANCE_API_KEY=partner-api-key
INSURANCE_QUOTE_URL=https://partner.example.com/quote
INSURANCE_BIND_URL=https://partner.example.com/bind
INSURANCE_CLAIM_URL=https://partner.example.com/claims
INSURANCE_TIMEOUT_SECONDS=12
